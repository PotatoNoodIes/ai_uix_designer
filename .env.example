# ──────────────────────────────────────────────
# UIX AI Agent — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit your real .env file to source control.

# ─── Google Gemini (Required for default Gemini usage) ───────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_google_gemini_api_key_here

# ─── OpenRouter (Optional — only needed if using OpenRouter models) ───────────
# Get your key from: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here

# ─── Clerk Auth (Required for usage limits) ──────────────────────────────────
# Get your key from: https://dashboard.clerk.com → Your App → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# ─── Upstash Redis (Required for IP-based demo limiting) ─────────────────────
# Create a free DB at: https://console.upstash.com → REST API tab
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
